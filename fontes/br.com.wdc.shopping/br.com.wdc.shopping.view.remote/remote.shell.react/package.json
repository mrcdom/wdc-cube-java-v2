{
  "name": "wdc-shopping-react",
  "license": "MIT",
  "author": "Marcelo Domingos <WeDoCode Consultoria LTDA>",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrcdom/wdc-cube-java-v2.git",
    "directory": "fontes/br.com.wdc.shopping/br.com.wdc.shopping.view.remote/remote.shell.react"
  },
  "source": "src/index.html",
  "targets": {
    "default": {
      "distDir": "../../../../work/frontend/remote.shell.react"
    }
  },
  "alias": {
    "@root/*": "./src/scripts/$1"
  },
  "scripts": {
    "clean": "rm -rf .parcel-cache ../../../../work/frontend/remote.shell.react",
    "copy-context": "mkdir -p ../../../../work/frontend/remote.shell.react && cp context.html ../../../../work/frontend/remote.shell.react/context.html",
    "inject-externals": "node scripts/inject-externals.js",
    "start": "npm run build && parcel watch --public-url ./",
    "watch": "npm run build && parcel watch --public-url ./",
    "watch:clean": "npm run clean && npm run build && parcel watch --public-url ./",
    "build": "parcel build --public-url ./ && npm run inject-externals && npm run copy-context",
    "build:clean": "npm run clean && parcel build --public-url ./ && npm run inject-externals && npm run copy-context",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@parcel/transformer-sass": "^2.16.4",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "parcel": "^2.13.3",
    "prettier": "^3.8.2",
    "process": "^0.11.10"
  },
  "dependencies": {
    "@swc-react/action-button": "^1.12.1",
    "@swc-react/button": "^1.12.1",
    "@swc-react/divider": "^1.12.1",
    "@swc-react/field-label": "^1.12.1",
    "@swc-react/progress-circle": "^1.12.1",
    "@swc-react/textfield": "^1.12.1",
    "@swc-react/theme": "^1.12.1",
    "clsx": "^2.1.1",
    "history": "^5.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "universal-cookie": "^7.2.2"
  }
}
