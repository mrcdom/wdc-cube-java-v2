{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WDC Shopping",
  "version": "1.0.0",
  "identifier": "br.com.wdc.shopping.desktop",
  "build": {
    "frontendDist": "../../../br.com.wdc.shopping.backend/src/main/resources/META-INF/resources/teavm",
    "devUrl": "http://shopping-wdc.localhost:8080/teavm"
  },
  "app": {
    "windows": [
      {
        "title": "WDC Shopping",
        "width": 800,
        "height": 850,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
